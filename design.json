        },
        "phoneFrame": {
          "strokeColor": "#111111",
          "strokeWidth": "8-10px",
          "radius": "44-52px",
          "surfaceColor": "#FFFFFF"
        }
      },
      "floatingPreviewCards": {
        "surfaceColor": "#FFFFFF",
        "borderRadius": "22-26px",
        "shadow": "0 18px 48px rgba(17,23,39,0.14)",
