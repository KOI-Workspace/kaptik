{
  "designSystem": {
    "meta": {
      "name": "Kaptik — Lavender Pulse",
      "version": "2.0.0",
      "product": "Kaptik (K-pop real-time subtitle translation service)",
      "customizations": [
        "Primary: purple #8B5CF6 (focus ring, links, inline action, active state)",
        "Secondary: pink #EC4899 (accent only — never CTA)",
        "Typography: Pretendard Variable (single family)",
        "CTA buttons: near-black #0A0A0A pill (not purple)",
        "Landing background: white canvas — no full-page gradients"
      ]
    },

    "colorPalette": {
      "primary": {
        "base": "#8B5CF6",
        "scale": {
          "50":  "#F5F3FF",
          "100": "#EDE9FE",
          "200": "#DDD6FE",
          "300": "#C4B5FD",
          "400": "#A78BFA",
          "500": "#8B5CF6",
          "600": "#7C3AED",
          "700": "#6D28D9",
          "800": "#5B21B6",
          "900": "#4C1D95",
          "950": "#2E1065"
        },
        "usage": {
          "primaryCtaSurface": "#0A0A0A",
          "primaryCtaText": "#FFFFFF",
          "inlineActionButton": "#8B5CF6",
          "linkText": "#7C3AED",
          "linkHoverText": "#6D28D9",
          "focusRing": "#8B5CF6",
          "barChartFill": "#7C3AED",
          "successBadgeText": "#5B21B6",
          "successBadgeSurface": "#EDE9FE",
          "carouselIndicatorActive": "#8B5CF6"
        }
      },
      "secondary": {
        "base": "#EC4899",
        "scale": {
          "50":  "#FDF2F8",
          "100": "#FCE7F3",
          "200": "#FBCFE8",
          "300": "#F9A8D4",
          "400": "#F472B6",
          "500": "#EC4899",
          "600": "#DB2777",
          "700": "#BE185D",
          "800": "#9D174D",
          "900": "#831843",
          "950": "#500724"
        },
        "usage": {
          "secondaryAccent": "#EC4899",
          "highlightTag": "#FBCFE8",
          "highlightTagText": "#9D174D",
          "decorativeUnderline": "#EC4899",
          "infoBadgeSurface": "#FCE7F3",
          "infoBadgeText": "#9D174D"
        }
      },
      "neutral": {
        "scale": {
          "0":   "#FFFFFF",
          "50":  "#FAFAFA",
          "100": "#F5F5F5",
          "200": "#EAEAEA",
          "300": "#D4D4D4",
          "400": "#A3A3A3",
          "500": "#737373",
          "600": "#525252",
          "700": "#404040",
          "800": "#262626",
          "900": "#171717",
          "950": "#0A0A0A"
        },
        "usage": {
          "pageBackground": "#FFFFFF",
          "cardSurface": "#FFFFFF",
          "subtleSurface": "#F5F5F5",
          "divider": "#EAEAEA",
          "border": "#EAEAEA",
          "borderStrong": "#D4D4D4",
          "textPrimary": "#0A0A0A",
          "textSecondary": "#525252",
          "textTertiary": "#A3A3A3",
          "textPlaceholder": "#A3A3A3",
          "textInverse": "#FFFFFF",
          "iconDefault": "#525252",
          "iconMuted": "#A3A3A3"
        }
      },
      "status": {
        "success": {
          "surface": "#EDE9FE",
          "text": "#5B21B6",
          "icon": "#7C3AED",
          "note": "그린 없음 — primary 보라 톤으로 통일"
        },
        "warning": {
          "surface": "#FEF3C7",
          "text": "#92400E",
          "icon": "#D97706"
        },
        "danger": {
          "surface": "#FEE2E2",
          "text": "#991B1B",
          "icon": "#DC2626",
          "buttonSurface": "#EF4444",
          "buttonSurfaceHover": "#DC2626",
          "buttonText": "#FFFFFF"
        },
        "info": {
          "surface": "#FCE7F3",
          "text": "#9D174D",
          "icon": "#EC4899"
        }
      }
    },

    "typography": {
      "fontFamily": {
        "primary": "'Pretendard Variable', 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif",
        "mono": "'JetBrains Mono', 'SF Mono', Menlo, monospace",
        "note": "Pretendard 단일 패밀리 원칙. 코드 블록만 모노스페이스 허용"
      },
      "fontWeight": {
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "scale": {
        "displayLarge":  { "size": "32px", "lineHeight": "40px", "weight": 700, "letterSpacing": "-0.02em", "usage": "히어로 헤드라인" },
        "displayMedium": { "size": "24px", "lineHeight": "32px", "weight": 700, "letterSpacing": "-0.01em", "usage": "섹션 타이틀" },
        "headingLarge":  { "size": "20px", "lineHeight": "28px", "weight": 600, "usage": "카드/패널 제목, 섹션 헤더" },
        "headingMedium": { "size": "16px", "lineHeight": "24px", "weight": 600, "usage": "그룹 헤더" },
        "headingSmall":  { "size": "14px", "lineHeight": "20px", "weight": 600, "usage": "카드 타이틀" },
        "bodyLarge":     { "size": "16px", "lineHeight": "24px", "weight": 400, "usage": "본문 기본 (긴 문장)" },
        "bodyMedium":    { "size": "14px", "lineHeight": "20px", "weight": 400, "usage": "일반 UI 텍스트" },
        "bodySmall":     { "size": "13px", "lineHeight": "18px", "weight": 400, "usage": "보조 정보, 설명문" },
        "caption":       { "size": "12px", "lineHeight": "16px", "weight": 400, "usage": "메타 정보, 타임스탬프" },
        "label":         { "size": "12px", "lineHeight": "16px", "weight": 500, "letterSpacing": "0.04em", "textTransform": "uppercase (영문 전용)", "usage": "영문 카테고리 라벨. 한글 라벨에는 uppercase 금지" },
        "micro":         { "size": "10px", "lineHeight": "14px", "weight": 500, "usage": "상태 라벨. 최소 허용 크기" },
        "metric":        { "size": "32px", "lineHeight": "40px", "weight": 600, "usage": "숫자 단독 지표 표시" },
        "buttonLabel":   { "size": "14px", "lineHeight": "20px", "weight": 500, "usage": "버튼 텍스트" }
      }
    },

    "spacing": {
      "scale": {
        "0":  "0px",
        "1":  "4px",
        "2":  "8px",
        "3":  "12px",
        "4":  "16px",
        "5":  "20px",
        "6":  "24px",
        "8":  "32px",
        "10": "40px",
        "12": "48px",
        "16": "64px",
        "20": "80px"
      },
      "componentPadding": {
        "buttonHorizontal": "20px",
        "buttonVertical": "10px",
        "inputHorizontal": "12px",
        "inputVertical": "10px",
        "cardInner": "20px"
      }
    },

    "borderRadius": {
      "none": "0px",
      "sm": "6px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "pill": "9999px",
      "usage": {
        "buttonPrimary": "9999px",
        "buttonSecondary": "9999px",
        "buttonGhost": "8px",
        "input": "8px",
        "card": "12px",
        "cardLarge": "16px",
        "panel": "12px",
        "badge": "9999px",
        "avatar": "9999px",
        "tooltip": "8px",
        "modal": "36px",
        "modalSmall": "24px",
        "modalAuthButton": "20px"
      }
    },

    "elevation": {
      "shadow": {
        "none":   "none",
        "xs":     "0 1px 2px rgba(10, 10, 10, 0.04)",
        "sm":     "0 1px 3px rgba(10, 10, 10, 0.06), 0 1px 2px rgba(10, 10, 10, 0.04)",
        "md":     "0 4px 8px rgba(10, 10, 10, 0.06), 0 2px 4px rgba(10, 10, 10, 0.04)",
        "lg":     "0 12px 24px rgba(10, 10, 10, 0.08), 0 4px 8px rgba(10, 10, 10, 0.04)",
        "xl":     "0 24px 48px rgba(10, 10, 10, 0.12)",
        "modal":  "0 30px 100px rgba(15, 23, 42, 0.24)",
        "focus":  "0 0 0 3px rgba(139, 92, 246, 0.2)",
        "focusPink": "0 0 0 3px rgba(236, 72, 153, 0.2)"
      },
      "usage": {
        "card": "sm (hover: md)",
        "popover": "lg",
        "modal": "modal",
        "dropdown": "md",
        "tooltipBubble": "md"
      }
    },

    "componentStyles": {
      "modal": {
        "overlay": {
          "surfaceColor": "rgba(10, 10, 10, 0.55)",
          "backdropBlur": "4px",
          "paddingX": "16px",
          "paddingY": "32px"
        },
        "shell": {
          "maxWidth": "560px",
          "maxWidthSmall": "320px",
          "surfaceColor": "#FFFFFF",
          "border": "1px solid rgba(255,255,255,0.7)",
          "borderRadius": "36px",
          "borderRadiusSmall": "24px",
          "padding": {
            "mobile": "28px 28px 36px",
            "desktop": "32px 40px 44px"
          },
          "shadow": "0 30px 100px rgba(15, 23, 42, 0.24)",
          "topGlow": "radial-gradient(circle at top, rgba(124, 140, 255, 0.14), transparent 68%)"
        },
        "content": {
          "maxWidth": "420px",
          "alignment": "center"
        },
        "header": {
          "eyebrow": {
            "fontSize": "11px",
            "fontWeight": 600,
            "letterSpacing": "0.24em",
            "textTransform": "uppercase",
            "textColor": "#A3A3A3"
          },
          "title": {
            "fontSize": { "mobile": "30px", "desktop": "32px" },
            "lineHeight": { "mobile": "38px", "desktop": "40px" },
            "fontWeight": 600,
            "letterSpacing": "-0.02em",
            "textColor": "#0A0A0A"
          },
          "description": {
            "fontSize": { "mobile": "15px", "desktop": "16px" },
            "lineHeight": "28px",
            "textColor": "#525252"
          }
        },
        "badge": {
          "size": "64px",
          "borderRadius": "24px"
        },
        "actions": {
          "primaryPill": {
            "surfaceColor": "#0A0A0A",
            "textColor": "#FFFFFF",
            "borderRadius": "9999px",
            "padding": "12px 24px",
            "fontSize": "14px",
            "fontWeight": 600,
            "hoverSurface": "#262626"
          },
          "dangerButton": {
            "surfaceColor": "#EF4444",
            "hoverSurface": "#DC2626",
            "textColor": "#FFFFFF",
            "borderRadius": "12px",
            "padding": "10px 0",
            "fontSize": "14px",
            "fontWeight": 600
          }
        },
        "interaction": {
          "closeOnOverlayClick": true,
          "closeIconDefault": false,
          "note": "기본 닫기: 배경 클릭. X 버튼은 명시적으로 필요한 경우에만"
        }
      },

      "actionControls": {
        "primaryButton": {
          "surfaceColor": "#0A0A0A",
          "textColor": "#FFFFFF",
          "borderRadius": "9999px",
          "padding": "10px 20px",
          "fontSize": "14px",
          "fontWeight": 500,
          "interactionStates": {
            "hoverSurface": "#262626",
            "activeSurface": "#404040",
            "disabledSurface": "#D4D4D4",
            "disabledText": "#A3A3A3",
            "focusRing": "0 0 0 3px rgba(139, 92, 246, 0.3)"
          }
        },
        "secondaryButton": {
          "surfaceColor": "#FFFFFF",
          "textColor": "#0A0A0A",
          "border": "1px solid #EAEAEA",
          "borderRadius": "9999px",
          "padding": "10px 20px",
          "fontSize": "14px",
          "fontWeight": 500,
          "interactionStates": {
            "hoverSurface": "#FAFAFA",
            "hoverBorder": "#D4D4D4",
            "activeSurface": "#F5F5F5"
          }
        },
        "ghostButton": {
          "surfaceColor": "transparent",
          "textColor": "#525252",
          "borderRadius": "8px",
          "padding": "8px 12px",
          "interactionStates": {
            "hoverSurface": "#F5F5F5",
            "hoverText": "#0A0A0A"
          }
        },
        "dangerButton": {
          "surfaceColor": "#DC2626",
          "textColor": "#FFFFFF",
          "borderRadius": "9999px",
          "padding": "10px 20px",
          "fontWeight": 500,
          "interactionStates": {
            "hoverSurface": "#B91C1C"
          }
        },
        "linkText": {
          "color": "#7C3AED",
          "fontWeight": 500,
          "textDecoration": "none",
          "interactionStates": {
            "hoverColor": "#6D28D9",
            "hoverDecoration": "underline"
          }
        }
      },

      "formInput": {
        "surfaceColor": "#FFFFFF",
        "border": "1px solid #EAEAEA",
        "borderRadius": "8px",
        "padding": "10px 12px",
        "fontSize": "14px",
        "textColor": "#0A0A0A",
        "placeholderColor": "#A3A3A3",
        "iconColor": "#A3A3A3",
        "interactionStates": {
          "hoverBorder": "#D4D4D4",
          "focusBorder": "#8B5CF6",
          "focusRing": "0 0 0 3px rgba(139, 92, 246, 0.15)",
          "errorBorder": "#DC2626",
          "errorRing": "0 0 0 3px rgba(220, 38, 38, 0.15)",
          "disabledSurface": "#FAFAFA",
          "disabledText": "#A3A3A3"
        }
      },

      "badge": {
        "default": {
          "surfaceColor": "#F5F5F5",
          "textColor": "#525252"
        },
        "success": {
          "surfaceColor": "#EDE9FE",
          "textColor": "#5B21B6",
          "iconColor": "#7C3AED",
          "note": "그린 없음 — 보라 톤으로 통일"
        },
        "info": {
          "surfaceColor": "#FCE7F3",
          "textColor": "#9D174D"
        },
        "warning": {
          "surfaceColor": "#FEF3C7",
          "textColor": "#92400E"
        },
        "danger": {
          "surfaceColor": "#FEE2E2",
          "textColor": "#991B1B"
        },
        "shape": {
          "borderRadius": "9999px",
          "padding": "2px 10px",
          "fontSize": "12px",
          "fontWeight": 500
        }
      }
    },

    "iconography": {
      "defaultStyle": "outlined",
      "strokeWidth": "1.5px",
      "library": "lucide-react",
      "size": {
        "sm": "14px",
        "md": "16px",
        "lg": "20px",
        "xl": "24px"
      },
      "colorRules": {
        "default": "#525252",
        "muted": "#A3A3A3",
        "active": "#8B5CF6",
        "decorativeIllustration": "#EC4899",
        "successCheck": "#7C3AED",
        "destructive": "#DC2626"
      }
    },

    "animation": {
      "durationDefault": "200ms",
      "durationSlow": "250ms",
      "durationLayout": "300ms",
      "easing": "ease-out",
      "note": "200–250ms ease-out이 디폴트. 느릿함은 신뢰감, 빠름은 가벼움. 300ms는 레이아웃 전환에만"
    },

    "qualityAssurance": {
      "doNot": [
        "CTA에 보라(#8B5CF6) 사용 — 독립 CTA는 #0A0A0A(검정) pill",
        "핑크(#EC4899)를 CTA에 사용 — 핑크는 accent/info 전용",
        "한글 라벨에 uppercase 적용",
        "Pretendard 외 한글 폰트 혼용",
        "그린·민트·청록을 신규 추가",
        "카드 안에 카드 중첩",
        "그림자 농도를 shadow-md 이상으로 카드에 적용 (기본: shadow-sm)",
        "Pretendard weight 400 미만 사용",
        "풀페이지 그라디언트 배경 (흰 캔버스 우선)"
      ],
      "doEnsure": [
        "Pretendard Variable이 모든 UI 렌더 전에 로드됨",
        "모든 status badge: pill(9999px) 형태 통일",
        "포커스 링: primary 보라 0.15–0.30 alpha",
        "Danger 액션(삭제): 반드시 확인 모달 경유",
        "모달 닫기: 배경 클릭 우선, X 버튼은 선택적",
        "아이콘: strokeWidth 1.5 통일"
      ],
      "accessibility": {
        "primaryOnWhite": {
          "color": "#7C3AED",
          "background": "#FFFFFF",
          "contrast": "5.42:1",
          "WCAG": "AA pass (normal text)"
        },
        "secondaryOnWhite": {
          "color": "#DB2777",
          "background": "#FFFFFF",
          "contrast": "4.83:1",
          "WCAG": "AA pass (normal text)"
        },
        "textPrimaryOnWhite": {
          "color": "#0A0A0A",
          "background": "#FFFFFF",
          "contrast": "20.45:1",
          "WCAG": "AAA pass"
        }
      }
    }
  }
}
