        "verticalMarkers": "#AEB8CB",
        "specularHighlights": "rgba(255,255,255,0.52)",
        "notes": [
          "Landscape is extremely low-contrast",
          "Forms are created through tone shifts, not strong borders"
        ]
      }
    },
    "stateArchitecture": {
      "buttons": {
        "default": "pills with high softness and minimal aggressive contrast",
        "hover": "slightly stronger shadow or border opacity",
        "active": "subtle scale down",
        "focus": {
          "ring": "0 0 0 3px rgba(94,156,255,0.22)"
        },
        "disabled": {
          "opacity": 0.45,
          "cursor": "not-allowed"
        }
      },
      "navLinks": {
        "default": "medium weight",
        "hover": "increase opacity / darken slightly",
        "active": "weight 600 and slightly darker than siblings"
      },
      "chips": {
        "default": "soft translucent white",
        "hover": "increase opacity and border visibility",
        "selected": {
          "surfaceColor": "#FFFFFF",
          "textColor": "#23263A",
          "shadow": "0 6px 18px rgba(17,23,39,0.08)"
        }
      },
      "featureCards": {
        "default": "matte translucent",
        "hover": "slightly stronger elevation",
        "active": "bright white emphasis panel"
      }
    },
    "hierarchicalRules": {
      "backgroundVsContent": [
        "Page-level gradients belong only on the main section background, never on cards or icons",
        "Cards and pills stay near-white or translucent white to preserve readability over gradients",
        "Dark hero uses solid black/navy field with glow objects, not multicolor full-page gradients"
      ],
      "typographyRules": [
        "Hero headlines use near-black on light backgrounds and near-white on dark backgrounds",
        "Support text is always muted gray-blue, never pure black",
        "Eyebrows are semibold/bold and tighter than body copy"
      ],
      "buttonRules": [
        "Primary CTAs on light backgrounds use filled white pills",
        "Utility or enterprise actions use outlined pills",
        "Dark sections preserve white text with transparent fills and white borders"
      ],
      "illustrationRules": [
        "Ambient visuals are low-contrast and soft-edged",
        "Tech objects use selective saturated accents only inside focal illustrations",
        "Do not spread accent colors across all UI controls"
      ]
    },
    "responsiveBehavior": {
      "desktop": {
        "heroHeadlineWidth": "50-70% of viewport",
        "featureListAndDevice": "two-column composition"
      },
      "tablet": {
        "navSpacing": "reduce by 20-25%",
        "headline": "decrease to 48-60px"
      },
      "mobile": {
        "stacking": "single column",
        "heroHeadline": "36-44px",
        "chips": "wrap into multiple rows",
        "nav": "collapse to menu/drawer"
      }
    },
    "accessibility": {
      "contrastGuidance": [
        "Primary headline on light background appears to exceed WCAG AA",
        "Muted gray secondary text over pale gradients may fall near AA threshold at smaller sizes",
        "Outlined buttons on very light backgrounds need minimum 3:1 visible boundary contrast"
      ],
      "recommendations": [
        "Use #5F667C or darker for secondary text smaller than 18px",
        "Increase border opacity on translucent chips for keyboard/focus clarity",
        "Do not place light gray text directly over bright bloom regions without a subtle shadow or darker token"
      ]
    },
    "implementationGuardrails": {
      "avoid": [
        "Applying the page gradient to buttons, cards, or iconography",
        "Using pure black body copy on light theme sections",
        "Adding heavy drop shadows to every object",
        "Turning the soft atmospheric landscape into sharply outlined shapes",
        "Making all buttons filled; outline treatment is essential to the system"
      ],
      "ensure": [
        "Consistent pill radius across chips and buttons",
        "Large negative letter spacing on hero headlines",
        "Soft translucency for supporting panels in light sections",
        "Sparse use of saturated accent colors only in hero visuals and preview content",
        "Very clean, low-noise spacing with lots of empty space"
      ]
    }
  }
}